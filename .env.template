# .env.template — chaves de configuração de uma conta.
#
# Cada conta tem o seu próprio account/<server>/<user>/.env (em ~/travian).
# Ao iniciar, o bot confere se aquele .env tem TODAS as chaves listadas aqui
# (item XIV) e avisa as que faltam. Chaves ausentes caem no default do código;
# este arquivo é a referência canônica do que existe para configurar.

# --- credenciais (obrigatórias) ---
TRAVIAN_BASE=https://ts6.x1.america.travian.com
TRAVIAN_EMAIL=voce@exemplo.com
TRAVIAN_PASSWORD=sua_senha

# --- herói: para onde vão os pontos de atributo ---
# producao | ataque | defesa
HEROI_ATRIBUTO=producao

# --- estratégia de ataque (montada ao iniciar, lendo o histórico do SQLite) ---
# sem_perdas (padrão) | agressivo | defensivo
ESTRATEGIA=sem_perdas

# --- estruturas obrigatórias: ID(nível-alvo); ... (evolução uniforme) ---
# A cada passo, sobe a que está MAIS LONGE do alvo. Use o ID do prédio (gid do
# jogo, em build.php?id=<slot>&gid=<ID>) — é determinístico (nome também é
# aceito, mas dá margem a erro de texto). Muro = qualquer gid de muralha
# (31/32/33/42/43); resolve sozinho pela tribo.
# IDs: 10=Armazém 11=Celeiro 13=Ferraria 15=Edifício Principal
#      16=Ponto de Encontro 17=Mercado 18=Embaixada 19=Quartel 20=Estábulo
#      21=Oficina 22=Academia 23=Esconderijo 24=Câmara Municipal 25=Residência
#      26=Palácio 27=Tesouro 31=Muralha 37=Mansão do Herói
ESTRUTURAS=10(5);18(1);16(5);11(5);23(10);31(3)

# --- esconderijo (cranny): nível-alvo (~capacidade 2000) ---
CRANNY_NIVEL_ALVO=10

# --- dorf2: criar edifício novo em vez de só evoluir ---
# DORF2_NOVOS = gids desejados por prioridade; DORF2_PCT_NOVO = % de chance.
DORF2_NOVOS=18,23,17
DORF2_PCT_NOVO=0

# --- muro: nível-alvo a atingir ANTES de a proteção de iniciante acabar ---
MURO_NIVEL_ALVO=5
# MURO_GID força o gid do muro (senão deduz pela tribo). Opcional — descomente:
#MURO_GID=31

# --- exército (SÓ no modo agressivo) ---
# Alvo de tropas = EXERCITO_PCT_POP% da população (0 = desligado). Treina aos
# poucos: EXERCITO_LOTE unidades por ciclo, da unidade EXERCITO_TROPA (tN), no
# quartel (gid 19), que é construído pelo dorf2 se faltar. (Romano: t1 = legio.)
EXERCITO_PCT_POP=50
EXERCITO_TROPA=t1
EXERCITO_LOTE=5

# --- oásis (assalto automático) ---
# OASIS_ATIVO força ligado; OASIS_AUTO liga sozinho ao detectar exército;
# OASIS_CHECK_H = intervalo (h) de checagem de exército enquanto não há tropa;
# OASIS_HEROI_OBRIGATORIO = exige herói em casa para enviar.
OASIS_ATIVO=false
OASIS_AUTO=true
OASIS_CHECK_H=6
OASIS_HEROI_OBRIGATORIO=true
